# iFood Credentials
# Available in iFood Developer Portal
IFOOD_CLIENT_ID=your_client_id_here
IFOOD_CLIENT_SECRET=your_client_secret_here
IFOOD_MERCHANT_ID=your_merchant_id_here
IFOOD_WEBHOOK_SECRET=your_webhook_secret_here

# Telegram Credentials
# Available from BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# AWS Configuration (Optional if running locally with env vars)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
